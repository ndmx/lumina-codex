{
  "name": "Lumina Codex",
  "version": "0.5.0",
  "purpose": "Portable design-system source for apps, websites, web apps, native apps, documents, presentations, and rendered software surfaces.",
  "entrypoint": "LUMINA.md",
  "agentInstructions": "AGENTS.md",
  "canonicalSystemPath": "docs/system",
  "constitution": "docs/constitution.md",
  "designConstitution": "docs/system/design-constitution.md",
  "designVariationsPath": "docs/design-variations",
  "sensitiveBoundary": "../AppDEVguideS",
  "package": {
    "name": "@xlumina/system",
    "source": "packages/lumina-system",
    "install": "npm install @xlumina/system",
    "entry": "packages/lumina-system/src/index.ts",
    "cli": "npx lumina  (record | audit | close | meta)",
    "cliSource": "packages/lumina-system/bin/lumina.mjs",
    "feedbackEnv": "LUMINA_FEEDBACK_URL — POST events to a central Lumina instead of a local file",
    "published": true,
    "registry": "https://www.npmjs.com/package/@xlumina/system",
    "publishedVersion": "1.0.2",
    "localVersion": "1.0.4",
    "description": "Framework-agnostic executable brain: tokens, eras, schemes, appearance preferences, grid, variation, surface treatments, platform-rules, and the recursive-improvement loop. Zero runtime dependencies. Ships a `lumina` CLI."
  },
  "systemModules": {
    "constitution": "packages/lumina-system/src/constitution.ts",
    "tokens": "packages/lumina-system/src/tokens.ts",
    "eras": "packages/lumina-system/src/eras.ts",
    "scheme": "packages/lumina-system/src/scheme.ts",
    "appearance": "packages/lumina-system/src/appearance.ts",
    "surface": "packages/lumina-system/src/surface.ts",
    "grid": "packages/lumina-system/src/grid.ts",
    "variation": "packages/lumina-system/src/variation.ts",
    "platformRules": "packages/lumina-system/src/platform-rules.ts",
    "registry": "packages/lumina-system/src/registry.ts",
    "designVariations": "packages/lumina-system/src/design-variations.ts",
    "feedback": "packages/lumina-system/src/feedback.ts",
    "improvementLedger": "packages/lumina-system/src/improvement-ledger.ts",
    "invariants": "packages/lumina-system/src/invariants.ts",
    "fitness": "packages/lumina-system/src/fitness.ts",
    "evaluation": "packages/lumina-system/src/evaluation.ts",
    "closer": "packages/lumina-system/src/closer.ts",
    "meta": "packages/lumina-system/src/meta.ts"
  },
  "recursiveLoop": {
    "doc": "docs/system/recursive-loop.md",
    "ledger": "lumina-ledger.jsonl",
    "state": "lumina-state.json",
    "audit": "scripts/lumina-audit.mjs",
    "auditCommand": "npm run lumina:audit",
    "report": "docs/system/fitness-report.md",
    "evaluate": "scripts/lumina-evaluate.mjs",
    "evaluateCommand": "npm run lumina:evaluate",
    "evaluationReport": "docs/system/evaluation-report.md",
    "close": "scripts/lumina-close.mjs",
    "closeCommand": "npm run lumina:close",
    "closeReport": "docs/system/close-report.md",
    "meta": "scripts/lumina-meta.mjs",
    "metaCommand": "npm run lumina:meta",
    "metaReport": "docs/system/meta-report.md",
    "stages": "1-5 built (observe, score, propose, evaluate, apply, meta-guard); autonomous source-file edits intentionally left human-gated"
  },
  "tokenSource": "packages/lumina-system/src/tokens.ts",
  "eraSource": "packages/lumina-system/src/eras.ts",
  "publicRegistry": "packages/lumina-system/src/registry.ts",
  "designVariationRegistry": "packages/lumina-system/src/design-variations.ts",
  "integrationGuide": "docs/system/integration-guide.md",
  "readOrder": [
    "LUMINA.md",
    "docs/system/README.md",
    "docs/system/design-constitution.md",
    "docs/system/platform-taxonomy.md",
    "docs/system/naming-and-tags.md",
    "docs/system/element-model.md",
    "docs/system/scheme-grid-variation.md",
    "docs/system/mobile-vs-web.md",
    "docs/system/background-as-surface.md",
    "docs/system/integration-guide.md",
    "docs/system/registry.md",
    "docs/design-variations",
    "docs/system/continuous-improvement.md",
    "docs/system/recursive-loop.md"
  ],
  "canonicalConcepts": {
    "sharedSpace": {
      "name": "Shared Space",
      "approvedAliases": {
        "generic collaboration app": "Group",
        "personal memory app": "Circle",
        "safety app": "Trusted Contacts"
      }
    }
  },
  "defaultTags": [
    "design-system",
    "mobile",
    "web",
    "web-app",
    "native-app",
    "ios-app",
    "react",
    "typescript",
    "swiftui"
  ],
  "continuousImprovement": {
    "workflow": "docs/system/continuous-improvement.md",
    "log": "docs/system/improvement-log.md",
    "registry": "docs/system/registry.md"
  },
  "designVariations": [
    {
      "id": "design-variation-01",
      "name": "Design Variation 01: Pearl Planner Glass",
      "platforms": ["ios", "ipados", "browser", "macos"],
      "frameworks": ["swiftui", "react", "nextjs", "css"],
      "defaultEra": "atelier",
      "surfaceTreatment": "pearl-paper/light with outline-glass controls",
      "codeSignature": "Lumina Design System · Variation 01 · Created by ndmx",
      "pairsWith": "design-variation-02"
    },
    {
      "id": "design-variation-02",
      "name": "Design Variation 02: Smoked Graphite Glass",
      "platforms": ["ios", "ipados", "browser", "macos"],
      "frameworks": ["swiftui", "react", "nextjs", "css"],
      "defaultEra": "atelier",
      "surfaceTreatment": "smoked-graphite/dark with glass controls",
      "appearancePreference": "System | Light | Dark",
      "codeSignature": "Lumina Design System · Variation 02 · Created by ndmx",
      "pairsWith": "design-variation-01"
    },
    {
      "id": "design-variation-03",
      "name": "Design Variation 03: Chrome Pearl Memory Surface",
      "platforms": ["ios", "ipados", "browser"],
      "frameworks": ["swiftui", "react", "nextjs", "css"],
      "defaultEra": "atelier",
      "surfaceTreatment": "chrome-pearl/outline-glass",
      "codeSignature": "Lumina Design System · Variation 03 · Created by ndmx"
    },
    {
      "id": "design-variation-04",
      "name": "Design Variation 04: Map Safety Glass",
      "platforms": ["ios", "ipados", "browser", "android"],
      "frameworks": ["swiftui", "react", "nextjs", "css"],
      "defaultEra": "atelier",
      "surfaceTreatment": "map-glass/solid-for-dense-safety-data",
      "codeSignature": "Lumina Design System · Variation 04 · Created by ndmx"
    }
  ]
}
